  <owl:Class rdf:about="https://w3id.org/promess/ontology#ArthriteClinique">
    <rdfs:label xml:lang="fr">ArthriteClinique</rdfs:label>
    <rdfs:comment xml:lang="en">Clinically manifest arthritis.</rdfs:comment>
    <rdfs:isDefinedBy>
      <owl:Ontology rdf:about="https://w3id.org/promess/ontology">
        <rdfs:label xml:lang="en">PROMESS Ontology</rdfs:label>
        <rdfs:label xml:lang="fr">Ontologie PROMESS</rdfs:label>
        <dcterms:title xml:lang="en">PROMESS Ontology</dcterms:title>
        <dcterms:title xml:lang="fr">Ontologie PROMESS</dcterms:title>
        <dcterms:description xml:lang="en">Draft version of the PROMESS ontology prepared for conceptual modeling, review, documentation, and further refinement.</dcterms:description>
        <dcterms:description xml:lang="fr">Version préliminaire de l’ontologie PROMESS préparée pour la modélisation conceptuelle, la revue, la documentation et l’affinement ultérieur.</dcterms:description>
        <dcterms:creator>Nushrat Jahan</dcterms:creator>
        <dcterms:creator>Lylia Abrouk</dcterms:creator>
        <dcterms:creator>Sandra Bringay</dcterms:creator>
        <dcterms:creator>Zubeyir Salis</dcterms:creator>
        <dcterms:publisher xml:lang="fr">Université de Montpellier, LIRMM; INSERM, PhyMedExp</dcterms:publisher>
        <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <vann:preferredNamespacePrefix>promess</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://w3id.org/promess/ontology#</vann:preferredNamespaceUri>
        <owl:versionInfo xml:lang="en">Draft v0.1</owl:versionInfo>
        <owl:versionIRI rdf:resource="https://w3id.org/promess/ontology/0.1-draft"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-06</dcterms:created>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-06</dcterms:modified>
        <dcterms:language>en</dcterms:language>
        <dcterms:language>fr</dcterms:language>
      </owl:Ontology>
    </rdfs:isDefinedBy>
    <rdfs:subClassOf rdf:resource="https://w3id.org/promess/ontology#ConditionMedicale"/>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/promess/ontology#VisiteInclusion">
    <rdfs:label xml:lang="fr">VisiteInclusion</rdfs:label>
