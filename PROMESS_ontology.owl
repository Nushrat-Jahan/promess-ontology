  <owl:ObjectProperty rdf:about="https://w3id.org/promess/ontology#interagitAvec">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:label xml:lang="fr">interagitAvec</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/promess/ontology#FacteurDeRisque"/>
    <rdfs:range rdf:resource="https://w3id.org/promess/ontology#FacteurDeRisque"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/promess/ontology"/>
    <rdfs:comment xml:lang="en">Interaction between risk factors. Suggested cardinality: FacteurDeRisque -&gt; FacteurDeRisque = 0..*.</rdfs:comment>
    <owl:inverseOf rdf:resource="https://w3id.org/promess/ontology#interagitAvec"/>
  </owl:ObjectProperty>
