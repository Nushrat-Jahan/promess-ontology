        <owl:inverseOf rdf:resource="https://w3id.org/promess/ontology#concerneParticipantResultat"/>
        <rdfs:domain rdf:resource="https://w3id.org/promess/ontology#Participant"/>
        <rdfs:range rdf:resource="https://w3id.org/promess/ontology#ResultatClinique"/>
