    <!-- https://w3id.org/promess/ontology#aTemporalite -->


    <owl:ObjectProperty rdf:about="https://w3id.org/promess/ontology#aTemporalite">
        <owl:inverseOf rdf:resource="https://w3id.org/promess/ontology#temporaliteDeVisite"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/promess/ontology#Visite"/>
        <rdfs:range rdf:resource="https://w3id.org/promess/ontology#TempsSuivi"/>
