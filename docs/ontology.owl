     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://w3id.org/promess/ontology">
        <owl:versionIRI rdf:resource="https://w3id.org/promess/ontology/0.1-draft"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-06</terms:created>
        <terms:creator>Nushrat Jahan</terms:creator>
        <terms:creator>Lylia Abrouk</terms:creator>
        <terms:creator>Sandra Bringay</terms:creator>
        <terms:creator>Zubeyir Salis</terms:creator>
        <terms:description xml:lang="en">Draft version of the PROMESS ontology prepared for conceptual modeling, review, documentation, and further refinement.</terms:description>
        <terms:description xml:lang="fr">Version préliminaire de l’ontologie PROMESS préparée pour la modélisation conceptuelle, la revue, la documentation et l’affinement ultérieur.</terms:description>
        <terms:language>en</terms:language>
        <terms:language>fr</terms:language>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-06</terms:modified>
        <terms:publisher xml:lang="fr">Université de Montpellier, LIRMM; INSERM, PhyMedExp</terms:publisher>
        <terms:title xml:lang="fr">Ontologie PROMESS</terms:title>
        <terms:title xml:lang="en">PROMESS Ontology</terms:title>
        <vann:preferredNamespacePrefix>promess</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://w3id.org/promess/ontology#</vann:preferredNamespaceUri>
        <rdfs:label xml:lang="fr">Ontologie PROMESS</rdfs:label>
        <rdfs:label xml:lang="en">PROMESS Ontology</rdfs:label>
        <owl:versionInfo xml:lang="en">Draft v0.1</owl:versionInfo>
    </owl:Ontology>
    


