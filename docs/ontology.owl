    <!-- https://w3id.org/promess/ontology#aAgentExpositionAir -->


    <owl:ObjectProperty rdf:about="https://w3id.org/promess/ontology#aAgentExpositionAir">
        <rdfs:domain rdf:resource="https://w3id.org/promess/ontology#ExpositionAir"/>
        <rdfs:range rdf:resource="https://w3id.org/promess/ontology#AgentExposition"/>
        <rdfs:comment xml:lang="en">Exposure agent for air exposure. Suggested cardinality: ExpositionAir -&gt; AgentExposition = 0..*.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/promess/ontology"/>
        <rdfs:label xml:lang="fr">aAgentExpositionAir</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/promess/ontology#aAgentExpositionChimique -->


    <owl:ObjectProperty rdf:about="https://w3id.org/promess/ontology#aAgentExpositionChimique">
