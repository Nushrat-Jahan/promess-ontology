                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Research study or protocol in which participants are followed.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/promess/ontology"/>
        <rdfs:label xml:lang="fr">Étude</rdfs:label>
    </owl:Class>
    


