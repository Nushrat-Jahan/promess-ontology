:ConsommationEau rdf:type owl:Class ;
                 rdfs:comment "Water consumption descriptor."@en ;
                 rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                 rdfs:label "ConsommationEau"@fr .


###  https://w3id.org/promess/ontology#Coping
:Coping rdf:type owl:Class ;
        rdfs:subClassOf :FacteurPsychologique ;
        rdfs:comment "Coping style or mechanism."@en ;
        rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
        rdfs:label "Coping"@fr .


###  https://w3id.org/promess/ontology#Depression
:Depression rdf:type owl:Class ;
            rdfs:subClassOf :FacteurPsychologique ;
            rdfs:comment "Depression-related psychological factor."@en ;
            rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
            rdfs:label "Dépression"@fr .


###  https://w3id.org/promess/ontology#Dissociation
:Dissociation rdf:type owl:Class ;
              rdfs:subClassOf :FacteurPsychologique ;
              rdfs:comment "Dissociation-related psychological factor."@en ;
              rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
              rdfs:label "Dissociation"@fr .


###  https://w3id.org/promess/ontology#DosagePolluants
:DosagePolluants rdf:type owl:Class ;
                 rdfs:subClassOf :Biomarqueur ;
                 rdfs:comment "Pollutant dosage biomarker/result type."@en ;
                 rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                 rdfs:label "DosagePolluants"@fr .


###  https://w3id.org/promess/ontology#Echographie
:Echographie rdf:type owl:Class ;
             rdfs:subClassOf :ExamenImagerie ;
             owl:disjointWith :IRM ;
             rdfs:comment "Ultrasound examination."@en ;
             rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
             rdfs:label "Échographie"@fr .


###  https://w3id.org/promess/ontology#Echographiste
:Echographiste rdf:type owl:Class ;
               rdfs:subClassOf :Medecin ;
               rdfs:comment "Ultrasound specialist; modeled as a kind of physician."@en ;
               rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
               rdfs:label "Échographiste"@fr .


###  https://w3id.org/promess/ontology#Etude
:Etude rdf:type owl:Class ;
       rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :aSite ;
                         owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onClass :Lieu
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :identifiantEtude ;
                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onDataRange xsd:string
                       ] ;
       rdfs:comment "Research study or protocol in which participants are followed."@en ;
       rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
       rdfs:label "Étude"@fr .


###  https://w3id.org/promess/ontology#Evenement
:Evenement rdf:type owl:Class ;
           rdfs:subClassOf [ rdf:type owl:Restriction ;
                             owl:onProperty :concerneParticipantEvenement ;
                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :Participant
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :survientLorsDe ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :Visite
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :dateEvenement ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onDataRange xsd:date
                           ] ;
           rdfs:comment "Relevant event occurring during study follow-up."@en ;
           rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
           rdfs:label "Événement"@fr .


###  https://w3id.org/promess/ontology#ExamenImagerie
:ExamenImagerie rdf:type owl:Class ;
                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                  owl:onProperty :concerneParticipantExamen ;
                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass :Participant
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :examenRealiseLorsDe ;
                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass :Visite
                                ] ;
                rdfs:comment "Imaging examination performed during follow-up."@en ;
                rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                rdfs:label "ExamenImagerie"@fr .


###  https://w3id.org/promess/ontology#Exposition
:Exposition rdf:type owl:Class ;
            rdfs:subClassOf [ rdf:type owl:Restriction ;
                              owl:onProperty :concerneParticipantExposition ;
                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass :Participant
                            ] ;
            rdfs:comment "Any exposure relevant to the participant or disease process."@en ;
            rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
            rdfs:label "Exposition"@fr .


###  https://w3id.org/promess/ontology#ExpositionAir
:ExpositionAir rdf:type owl:Class ;
               rdfs:subClassOf :ExpositionEnvironnementale ;
               rdfs:comment "Exposure through air."@en ;
               rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
               rdfs:label "ExpositionAir"@fr .


###  https://w3id.org/promess/ontology#ExpositionAlimentaire
:ExpositionAlimentaire rdf:type owl:Class ;
                       rdfs:subClassOf :Exposition ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :aConsommationEau ;
                                         owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                         owl:onClass :ConsommationEau
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :aFrequenceConsommation ;
                                         owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                         owl:onClass :FrequenceConsommation
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :aHabitudeAlimentaire ;
                                         owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                         owl:onClass :HabitudeAlimentaire
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :aModeCuisson ;
                                         owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                         owl:onClass :ModeCuisson
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :aNiveauTransformation ;
                                         owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                         owl:onClass :NiveauTransformation
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :aOrigineAliments ;
                                         owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                         owl:onClass :OrigineAliments
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :aRegimeAlimentaire ;
                                         owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                         owl:onClass :RegimeAlimentaire
                                       ] ;
                       rdfs:comment "Dietary exposure."@en ;
                       rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                       rdfs:label "ExpositionAlimentaire"@fr .


