                                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onDataRange xsd:decimal
                                           ] ;
                           rdfs:comment "Anthropometric parameter."@en ;
                           rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                           rdfs:label "ParamètreAnthropométrique"@fr .


###  https://w3id.org/promess/ontology#Participant
:Participant rdf:type owl:Class ;
             rdfs:subClassOf :Personne ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :estSuiviDans ;
                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onClass :Etude
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :appartientAuGroupe ;
                               owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onClass :GroupeDeParticipants
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :identifiantParticipant ;
                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onDataRange xsd:string
                             ] ;
             rdfs:comment "Person enrolled or followed in the study."@en ;
             rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
             rdfs:label "Participant"@fr .


