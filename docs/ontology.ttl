:Legumes rdf:type owl:Class ;
         rdfs:subClassOf :TypeAliment ;
         owl:disjointWith :Poisson ,
                          :ProduitsLaitiers ,
                          :Snacks ,
                          :Sucreries ,
                          :Viande ;
         rdfs:comment "Vegetables."@en ;
         rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
