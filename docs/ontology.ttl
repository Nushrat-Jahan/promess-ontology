         rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
         rdfs:label "Cellule"@fr .


###  https://w3id.org/promess/ontology#Cereales
:Cereales rdf:type owl:Class ;
          rdfs:subClassOf :TypeAliment ;
          owl:disjointWith :Fruits ,
                           :Legumes ,
                           :Poisson ,
                           :ProduitsLaitiers ,
                           :Snacks ,
                           :Sucreries ,
                           :Viande ;
          rdfs:comment "Cereals/grains."@en ;
          rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
          rdfs:label "Céréales"@fr .


###  https://w3id.org/promess/ontology#Cheveux
:Cheveux rdf:type owl:Class ;
         rdfs:subClassOf :PrelevementBiologique ;
