###  https://w3id.org/promess/ontology#Boissons
:Boissons rdf:type owl:Class ;
          rdfs:subClassOf :TypeAliment ;
          owl:disjointWith :Cereales ,
                           :Fruits ,
                           :Legumes ,
                           :Poisson ,
                           :ProduitsLaitiers ,
                           :Snacks ,
                           :Sucreries ,
                           :Viande ;
          rdfs:comment "Beverages."@en ;
          rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
          rdfs:label "Boissons"@fr .


