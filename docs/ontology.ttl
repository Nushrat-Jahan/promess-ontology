###  https://w3id.org/promess/ontology#Lieu
:Lieu rdf:type owl:Class ;
      rdfs:subClassOf [ rdf:type owl:Restriction ;
                        owl:onProperty :latitude ;
                        owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:decimal
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :longitude ;
                        owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:decimal
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :nomLieu ;
                        owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ;
      rdfs:comment "Site, center, place, or physical location."@en ;
      rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
      rdfs:label "Lieu"@fr .


###  https://w3id.org/promess/ontology#Medecin
:Medecin rdf:type owl:Class ;
         rdfs:subClassOf :Investigateur ;
         rdfs:comment "Physician involved in participant care or study tasks."@en ;
         rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
         rdfs:label "Médecin"@fr .


###  https://w3id.org/promess/ontology#Mesure
:Mesure rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :concerneParticipantMesure ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :Participant
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :estRealiseeLorsDe ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :Visite
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :aUnite ;
                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :aValeurNumerique ;
                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:decimal
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :aValeurTexte ;
                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ;
        rdfs:comment "Any measurement collected in the study."@en ;
        rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
        rdfs:label "Mesure"@fr .


###  https://w3id.org/promess/ontology#MesureBiologique
:MesureBiologique rdf:type owl:Class ;
                  rdfs:subClassOf :Mesure ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :aUniteBiomarqueur ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :aValeurBiomarqueur ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:decimal
                                  ] ;
                  rdfs:comment "Biological measurement."@en ;
                  rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                  rdfs:label "MesureBiologique"@fr .


