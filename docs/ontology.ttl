@prefix : <https://w3id.org/promess/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/promess/ontology#> .

<https://w3id.org/promess/ontology> rdf:type owl:Ontology ;
                                     owl:versionIRI <https://w3id.org/promess/ontology/0.1-draft> ;
                                     <http://purl.org/dc/terms/created> "2026-04-06"^^xsd:date ;
                                     <http://purl.org/dc/terms/creator> "Nushrat Jahan" ,
                                                                        "Lylia Abrouk" ,
                                                                        "Sandra Bringay" ,
                                                                        "Zubeyir Salis" ;
                                     <http://purl.org/dc/terms/description> "Draft version of the PROMESS ontology prepared for conceptual modeling, review, documentation, and further refinement."@en ,
                                                                            "Version préliminaire de l’ontologie PROMESS préparée pour la modélisation conceptuelle, la revue, la documentation et l’affinement ultérieur."@fr ;
                                     <http://purl.org/dc/terms/language> "en" ,
                                                                         "fr" ;
                                     <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                     <http://purl.org/dc/terms/modified> "2026-04-06"^^xsd:date ;
                                     <http://purl.org/dc/terms/publisher> "Université de Montpellier, LIRMM; INSERM, PhyMedExp"@fr ;
                                     <http://purl.org/dc/terms/title> "Ontologie PROMESS"@fr ,
                                                                      "PROMESS Ontology"@en ;
                                     <http://purl.org/vocab/vann/preferredNamespacePrefix> "promess" ;
                                     <http://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/promess/ontology#" ;
                                     rdfs:label "Ontologie PROMESS"@fr ,
                                                "PROMESS Ontology"@en ;
                                     owl:versionInfo "Draft v0.1"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/language
<http://purl.org/dc/terms/language> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
<http://purl.org/dc/terms/modified> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/publisher
<http://purl.org/dc/terms/publisher> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/promess/ontology#aAgentExpositionAir
:aAgentExpositionAir rdf:type owl:ObjectProperty ;
                     rdfs:domain :ExpositionAir ;
                     rdfs:range :AgentExposition ;
                     rdfs:comment "Exposure agent for air exposure. Suggested cardinality: ExpositionAir -> AgentExposition = 0..*."@en ;
                     rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                     rdfs:label "aAgentExpositionAir"@fr .


###  https://w3id.org/promess/ontology#aAgentExpositionChimique
:aAgentExpositionChimique rdf:type owl:ObjectProperty ;
                          rdfs:domain :ExpositionChimique ;
                          rdfs:range :AgentExposition ;
                          rdfs:comment "Exposure agent for chemical exposure. Suggested cardinality: ExpositionChimique -> AgentExposition = 0..*."@en ;
                          rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                          rdfs:label "aAgentExpositionChimique"@fr .


###  https://w3id.org/promess/ontology#aAgentExpositionPollution
:aAgentExpositionPollution rdf:type owl:ObjectProperty ;
                           owl:inverseOf :agentPollutionDe ;
                           rdfs:domain :ExpositionPollution ;
                           rdfs:range :AgentExposition ;
                           rdfs:comment "Exposure agent for pollution exposure. Suggested cardinality: ExpositionPollution -> AgentExposition = 0..*."@en ;
                           rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                           rdfs:label "aAgentExpositionPollution"@fr .


###  https://w3id.org/promess/ontology#aAgentExpositionProfessionnelle
:aAgentExpositionProfessionnelle rdf:type owl:ObjectProperty ;
                                 owl:inverseOf :agentProfessionnelDe ;
                                 rdfs:domain :ExpositionProfessionnelle ;
                                 rdfs:range :AgentExposition ;
                                 rdfs:comment "Exposure agent for occupational exposure. Suggested cardinality: ExpositionProfessionnelle -> AgentExposition = 0..*."@en ;
                                 rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                                 rdfs:label "aAgentExpositionProfessionnelle"@fr .


###  https://w3id.org/promess/ontology#aComplementAlimentaire
:aComplementAlimentaire rdf:type owl:ObjectProperty ;
                        rdfs:domain :ExpositionAlimentaire ;
                        rdfs:range :ComplementAlimentaire ;
                        rdfs:comment "Dietary supplement descriptor. Suggested cardinality: ExpositionAlimentaire -> ComplementAlimentaire = 0..*."@en ;
                        rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                        rdfs:label "aComplementAlimentaire"@fr .


###  https://w3id.org/promess/ontology#aCondition
:aCondition rdf:type owl:ObjectProperty ;
            owl:inverseOf :conditionChezParticipant ;
            rdfs:domain :Participant ;
            rdfs:range :ConditionMedicale ;
            rdfs:comment "Participant condition. Suggested cardinality: Participant -> ConditionMedicale = 0..*."@en ;
            rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
            rdfs:label "aCondition"@fr .


###  https://w3id.org/promess/ontology#aConsommationEau
:aConsommationEau rdf:type owl:ObjectProperty ;
                  owl:inverseOf :consommationEauDe ;
                  rdf:type owl:FunctionalProperty ;
                  rdfs:domain :ExpositionAlimentaire ;
                  rdfs:range :ConsommationEau ;
                  rdfs:comment "Water consumption descriptor. Suggested cardinality: ExpositionAlimentaire -> ConsommationEau = 0..1."@en ;
                  rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                  rdfs:label "aConsommationEau"@fr .


###  https://w3id.org/promess/ontology#aEvenement
:aEvenement rdf:type owl:ObjectProperty ;
            rdfs:domain :Participant ;
            rdfs:range :Evenement ;
            rdfs:comment "Study-relevant event for participant. Suggested cardinality: Participant -> Evenement = 0..*."@en ;
            rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
            rdfs:label "aEvenement"@fr .


###  https://w3id.org/promess/ontology#aExamenImagerie
:aExamenImagerie rdf:type owl:ObjectProperty ;
                 owl:inverseOf :concerneParticipantExamen ;
                 rdfs:domain :Participant ;
                 rdfs:range :ExamenImagerie ;
                 rdfs:comment "Participant imaging exam. Suggested cardinality: Participant -> ExamenImagerie = 0..*."@en ;
                 rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                 rdfs:label "aExamenImagerie"@fr .


###  https://w3id.org/promess/ontology#aFacteurDeRisque
:aFacteurDeRisque rdf:type owl:ObjectProperty ;
                  rdfs:domain :Participant ;
                  rdfs:range :FacteurDeRisque ;
                  rdfs:comment "General participant-risk-factor relation. Suggested cardinality: Participant -> FacteurDeRisque = 0..*."@en ;
                  rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                  rdfs:label "aFacteurDeRisque"@fr .


###  https://w3id.org/promess/ontology#aFacteurExpositionnel
:aFacteurExpositionnel rdf:type owl:ObjectProperty ;
                       rdfs:domain :ConditionMedicale ;
                       rdfs:range :Exposition ;
                       rdfs:comment "Inverse exposure-risk relation. Suggested cardinality: ConditionMedicale -> Exposition = 0..*."@en ;
                       rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                       rdfs:label "aFacteurExpositionnel"@fr .


###  https://w3id.org/promess/ontology#aFacteurPsychologique
:aFacteurPsychologique rdf:type owl:ObjectProperty ;
                       owl:inverseOf :facteurPsychologiqueChezParticipant ;
                       rdfs:domain :Participant ;
                       rdfs:range :FacteurPsychologique ;
                       rdfs:comment "Participant psychological factor. Suggested cardinality: Participant -> FacteurPsychologique = 0..*."@en ;
                       rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                       rdfs:label "aFacteurPsychologique"@fr .


###  https://w3id.org/promess/ontology#aFrequenceConsommation
:aFrequenceConsommation rdf:type owl:ObjectProperty ;
                        owl:inverseOf :frequenceDe ;
                        rdf:type owl:FunctionalProperty ;
                        rdfs:domain :ExpositionAlimentaire ;
                        rdfs:range :FrequenceConsommation ;
                        rdfs:comment "Consumption frequency descriptor. Suggested cardinality: ExpositionAlimentaire -> FrequenceConsommation = 0..1."@en ;
                        rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                        rdfs:label "aFrequenceConsommation"@fr .


###  https://w3id.org/promess/ontology#aHabitudeAlimentaire
:aHabitudeAlimentaire rdf:type owl:ObjectProperty ;
                      owl:inverseOf :habitudeDe ;
                      rdf:type owl:FunctionalProperty ;
                      rdfs:domain :ExpositionAlimentaire ;
                      rdfs:range :HabitudeAlimentaire ;
                      rdfs:comment "Dietary habit descriptor. Suggested cardinality: ExpositionAlimentaire -> HabitudeAlimentaire = 0..1."@en ;
                      rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                      rdfs:label "aHabitudeAlimentaire"@fr .


###  https://w3id.org/promess/ontology#aMesure
:aMesure rdf:type owl:ObjectProperty ;
         owl:inverseOf :concerneParticipantMesure ;
         rdfs:domain :Participant ;
         rdfs:range :Mesure ;
         rdfs:comment "Participant has measurements. Suggested cardinality: Participant -> Mesure = 0..*."@en ;
         rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
         rdfs:label "aMesure"@fr .


###  https://w3id.org/promess/ontology#aModeCuisson
:aModeCuisson rdf:type owl:ObjectProperty ;
              owl:inverseOf :modeCuissonDe ;
              rdf:type owl:FunctionalProperty ;
              rdfs:domain :ExpositionAlimentaire ;
              rdfs:range :ModeCuisson ;
              rdfs:comment "Cooking mode descriptor. Suggested cardinality: ExpositionAlimentaire -> ModeCuisson = 0..1."@en ;
              rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
              rdfs:label "aModeCuisson"@fr .


###  https://w3id.org/promess/ontology#aNiveauTransformation
:aNiveauTransformation rdf:type owl:ObjectProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain :ExpositionAlimentaire ;
                       rdfs:range :NiveauTransformation ;
                       rdfs:comment "Degree of processing descriptor. Suggested cardinality: ExpositionAlimentaire -> NiveauTransformation = 0..1."@en ;
                       rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                       rdfs:label "aNiveauTransformation"@fr .


###  https://w3id.org/promess/ontology#aOrigineAliments
:aOrigineAliments rdf:type owl:ObjectProperty ;
                  owl:inverseOf :origineDe ;
                  rdf:type owl:FunctionalProperty ;
                  rdfs:domain :ExpositionAlimentaire ;
                  rdfs:range :OrigineAliments ;
                  rdfs:comment "Food origin descriptor. Suggested cardinality: ExpositionAlimentaire -> OrigineAliments = 0..1."@en ;
                  rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                  rdfs:label "aOrigineAliments"@fr .


###  https://w3id.org/promess/ontology#aPrelevementBiologique
:aPrelevementBiologique rdf:type owl:ObjectProperty ;
                        owl:inverseOf :provientDeParticipant ;
                        rdfs:domain :Participant ;
                        rdfs:range :PrelevementBiologique ;
                        rdfs:comment "Participant biological sample collection. Suggested cardinality: Participant -> PrelevementBiologique = 0..*."@en ;
                        rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                        rdfs:label "aPrelevementBiologique"@fr .


###  https://w3id.org/promess/ontology#aRegimeAlimentaire
:aRegimeAlimentaire rdf:type owl:ObjectProperty ;
                    owl:inverseOf :regimeDe ;
                    rdf:type owl:FunctionalProperty ;
                    rdfs:domain :ExpositionAlimentaire ;
                    rdfs:range :RegimeAlimentaire ;
                    rdfs:comment "Dietary regimen descriptor. Suggested cardinality: ExpositionAlimentaire -> RegimeAlimentaire = 0..1."@en ;
                    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                    rdfs:label "aRegimeAlimentaire"@fr .


###  https://w3id.org/promess/ontology#aResultatClinique
:aResultatClinique rdf:type owl:ObjectProperty ;
                   owl:inverseOf :concerneParticipantResultat ;
                   rdfs:domain :Participant ;
                   rdfs:range :ResultatClinique ;
                   rdfs:comment "General outcome link. Suggested cardinality: Participant -> ResultatClinique = 0..*."@en ;
                   rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                   rdfs:label "aResultatClinique"@fr .


###  https://w3id.org/promess/ontology#aSigneClinique
:aSigneClinique rdf:type owl:ObjectProperty ;
                owl:inverseOf :signeChezParticipant ;
                rdfs:domain :Participant ;
                rdfs:range :SigneClinique ;
                rdfs:comment "Participant clinical sign. Suggested cardinality: Participant -> SigneClinique = 0..*."@en ;
                rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                rdfs:label "aSigneClinique"@fr .


###  https://w3id.org/promess/ontology#aSite
:aSite rdf:type owl:ObjectProperty ;
       owl:inverseOf :estSiteDe ;
       rdfs:domain :Etude ;
       rdfs:range :Lieu ;
       rdfs:comment "Study site or center. Suggested cardinality: Etude -> Lieu = 1..*."@en ;
       rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
       rdfs:label "aSite"@fr .


###  https://w3id.org/promess/ontology#aSubstanceTabagique
:aSubstanceTabagique rdf:type owl:ObjectProperty ;
                     owl:inverseOf :substanceTabagiqueDe ;
                     rdfs:domain :ExpositionTabagique ;
                     rdfs:range :SubstanceTabagique ;
                     rdfs:comment "Tobacco/cannabis descriptor. Suggested cardinality: ExpositionTabagique -> SubstanceTabagique = 0..*."@en ;
                     rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                     rdfs:label "aSubstanceTabagique"@fr .


###  https://w3id.org/promess/ontology#aTemporalite
:aTemporalite rdf:type owl:ObjectProperty ;
              owl:inverseOf :temporaliteDeVisite ;
              rdf:type owl:FunctionalProperty ;
              rdfs:domain :Visite ;
              rdfs:range :TempsSuivi ;
              rdfs:comment "Visit has one follow-up time point. Suggested cardinality: Visite -> TempsSuivi = 1."@en ;
              rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
              rdfs:label "aTemporalite"@fr .


###  https://w3id.org/promess/ontology#aTypeAliment
:aTypeAliment rdf:type owl:ObjectProperty ;
              owl:inverseOf :typeAlimentDe ;
              rdfs:domain :ExpositionAlimentaire ;
              rdfs:range :TypeAliment ;
              rdfs:comment "Food type descriptor. Suggested cardinality: ExpositionAlimentaire -> TypeAliment = 0..*."@en ;
              rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
              rdfs:label "aTypeAliment"@fr .


###  https://w3id.org/promess/ontology#aTypeDeVisite
:aTypeDeVisite rdf:type owl:ObjectProperty ;
               owl:inverseOf :typeDeVisiteDe ;
               rdf:type owl:FunctionalProperty ;
               rdfs:domain :Visite ;
               rdfs:range :TypeDeVisite ;
               rdfs:comment "Each visit must have exactly one visit type. Suggested cardinality: Visite -> TypeDeVisite = 1."@en ;
               rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
               rdfs:label "aTypeDeVisite"@fr .


###  https://w3id.org/promess/ontology#aVisite
:aVisite rdf:type owl:ObjectProperty ;
         rdfs:domain :Participant ;
         rdfs:range :Visite ;
         rdfs:comment "Participant may have many visits. Suggested cardinality: Participant -> Visite = 0..*."@en ;
         rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
         rdfs:label "aVisite"@fr .


###  https://w3id.org/promess/ontology#accueilleVisite
:accueilleVisite rdf:type owl:ObjectProperty ;
                 rdfs:domain :Lieu ;
                 rdfs:range :Visite ;
                 rdfs:comment "Location hosting visits. Suggested cardinality: Lieu -> Visite = 0..*."@en ;
                 rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                 rdfs:label "accueilleVisite"@fr .


###  https://w3id.org/promess/ontology#agentAirDe
:agentAirDe rdf:type owl:ObjectProperty ;
            owl:inverseOf :aAgentExpositionAir ;
            rdfs:domain :AgentExposition ;
            rdfs:range :ExpositionAir ;
            rdfs:comment "Inverse air agent relation. Suggested cardinality: AgentExposition -> ExpositionAir = 0..*."@en ;
            rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
            rdfs:label "agentAirDe"@fr .


###  https://w3id.org/promess/ontology#agentChimiqueDe
:agentChimiqueDe rdf:type owl:ObjectProperty ;
                 owl:inverseOf :aAgentExpositionChimique ;
                 rdfs:domain :AgentExposition ;
                 rdfs:range :ExpositionChimique ;
                 rdfs:comment "Inverse chemical agent relation. Suggested cardinality: AgentExposition -> ExpositionChimique = 0..*."@en ;
                 rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                 rdfs:label "agentChimiqueDe"@fr .


###  https://w3id.org/promess/ontology#agentPollutionDe
:agentPollutionDe rdf:type owl:ObjectProperty ;
                  rdfs:domain :AgentExposition ;
                  rdfs:range :ExpositionPollution ;
                  rdfs:comment "Inverse pollution agent relation. Suggested cardinality: AgentExposition -> ExpositionPollution = 0..*."@en ;
                  rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                  rdfs:label "agentPollutionDe"@fr .


###  https://w3id.org/promess/ontology#agentProfessionnelDe
:agentProfessionnelDe rdf:type owl:ObjectProperty ;
                      rdfs:domain :AgentExposition ;
                      rdfs:range :ExpositionProfessionnelle ;
                      rdfs:comment "Inverse occupational agent relation. Suggested cardinality: AgentExposition -> ExpositionProfessionnelle = 0..*."@en ;
                      rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                      rdfs:label "agentProfessionnelDe"@fr .


###  https://w3id.org/promess/ontology#analyseBiomarqueur
:analyseBiomarqueur rdf:type owl:ObjectProperty ;
                    owl:inverseOf :biomarqueurAnalyseDans ;
                    rdfs:domain :PrelevementBiologique ;
                    rdfs:range :Biomarqueur ;
                    rdfs:comment "Sample used for biomarker analysis. Suggested cardinality: PrelevementBiologique -> Biomarqueur = 0..*."@en ;
                    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                    rdfs:label "analyseBiomarqueur"@fr .


###  https://w3id.org/promess/ontology#appartientAEtude
:appartientAEtude rdf:type owl:ObjectProperty ;
                  owl:inverseOf :comprendVisite ;
                  rdf:type owl:FunctionalProperty ;
                  rdfs:domain :Visite ;
                  rdfs:range :Etude ;
                  rdfs:comment "Each visit belongs to one study. Suggested cardinality: Visite -> Etude = 1."@en ;
                  rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                  rdfs:label "appartientAEtude"@fr .


###  https://w3id.org/promess/ontology#appartientAEtudeGroupe
:appartientAEtudeGroupe rdf:type owl:ObjectProperty ;
                        owl:inverseOf :inclutGroupe ;
                        rdfs:domain :GroupeDeParticipants ;
                        rdfs:range :Etude ;
                        rdfs:comment "Inverse of group inclusion in study. Suggested cardinality: GroupeDeParticipants -> Etude = 0..*."@en ;
                        rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                        rdfs:label "appartientAEtudeGroupe"@fr .


###  https://w3id.org/promess/ontology#appartientAuGroupe
:appartientAuGroupe rdf:type owl:ObjectProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :Participant ;
                    rdfs:range :GroupeDeParticipants ;
                    rdfs:comment "Participant group membership. Suggested cardinality: Participant -> GroupeDeParticipants = 0..1."@en ;
                    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                    rdfs:label "appartientAuGroupe"@fr .


###  https://w3id.org/promess/ontology#biomarqueurAnalyseDans
:biomarqueurAnalyseDans rdf:type owl:ObjectProperty ;
                        rdfs:domain :Biomarqueur ;
                        rdfs:range :PrelevementBiologique ;
                        rdfs:comment "Inverse biomarker-analysis relation. Suggested cardinality: Biomarqueur -> PrelevementBiologique = 0..*."@en ;
                        rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                        rdfs:label "biomarqueurAnalyseDans"@fr .


###  https://w3id.org/promess/ontology#biomarqueurMesurePar
:biomarqueurMesurePar rdf:type owl:ObjectProperty ;
                      owl:inverseOf :mesureBiomarqueur ;
                      rdfs:domain :Biomarqueur ;
                      rdfs:range :MesureBiologique ;
                      rdfs:comment "Inverse biomarker-measurement relation. Suggested cardinality: Biomarqueur -> MesureBiologique = 0..*."@en ;
                      rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                      rdfs:label "biomarqueurMesurePar"@fr .


###  https://w3id.org/promess/ontology#complementDe
:complementDe rdf:type owl:ObjectProperty ;
              owl:inverseOf :aComplementAlimentaire ;
              rdfs:domain :ComplementAlimentaire ;
              rdfs:range :ExpositionAlimentaire ;
              rdfs:comment "Inverse supplement descriptor relation. Suggested cardinality: ComplementAlimentaire -> ExpositionAlimentaire = 0..*."@en ;
              rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
              rdfs:label "complementDe"@fr .


###  https://w3id.org/promess/ontology#comprendEvenement
:comprendEvenement rdf:type owl:ObjectProperty ;
                   rdfs:domain :Visite ;
                   rdfs:range :Evenement ;
                   rdfs:comment "Inverse of event during visit relation. Suggested cardinality: Visite -> Evenement = 0..*."@en ;
                   rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                   rdfs:label "comprendEvenement"@fr .


###  https://w3id.org/promess/ontology#comprendExamenImagerie
:comprendExamenImagerie rdf:type owl:ObjectProperty ;
                        owl:inverseOf :examenRealiseLorsDe ;
                        rdfs:domain :Visite ;
                        rdfs:range :ExamenImagerie ;
                        rdfs:comment "Visit includes imaging exams. Suggested cardinality: Visite -> ExamenImagerie = 0..*."@en ;
                        rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                        rdfs:label "comprendExamenImagerie"@fr .


###  https://w3id.org/promess/ontology#comprendMesure
:comprendMesure rdf:type owl:ObjectProperty ;
                rdfs:domain :Visite ;
                rdfs:range :Mesure ;
                rdfs:comment "Visit includes measurements. Suggested cardinality: Visite -> Mesure = 0..*."@en ;
                rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                rdfs:label "comprendMesure"@fr .


###  https://w3id.org/promess/ontology#comprendPrelevement
