                          :Salive ,
                          :Sang ,
                          :Selles ,
                          :Urines ;
         rdfs:comment "Hair sample."@en ;
         rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
         rdfs:label "Cheveux"@fr .


###  https://w3id.org/promess/ontology#Comorbidite
:Comorbidite rdf:type owl:Class ;
             rdfs:subClassOf :ConditionMedicale ;
             rdfs:comment "Coexisting medical condition; kept distinct from medical history."@en ;
             rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
             rdfs:label "Comorbidité"@fr .


