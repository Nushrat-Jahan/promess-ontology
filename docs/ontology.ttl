:ComplementAlimentaire rdf:type owl:Class ;
                       rdfs:comment "Dietary supplement descriptor."@en ;
                       rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                       rdfs:label "ComplémentAlimentaire"@fr .


###  https://w3id.org/promess/ontology#ConditionMedicale
:ConditionMedicale rdf:type owl:Class ;
                   rdfs:comment "Disease, syndrome, comorbidity, or medically relevant condition."@en ;
                   rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                   rdfs:label "ConditionMédicale"@fr .


###  https://w3id.org/promess/ontology#ConfirmationEchographique
:ConfirmationEchographique rdf:type owl:Class ;
                           rdfs:subClassOf :ResultatDeConfirmation ;
                           rdfs:comment "Ultrasound-based confirmation result."@en ;
                           rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
                           rdfs:label "ConfirmationÉchographique"@fr .


