@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix promess: <https://w3id.org/promess/ontology#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

promess:ACPA a owl:Class ;
    rdfs:label "ACPA"@fr ;
    rdfs:comment "Anti-citrullinated protein antibodies biomarker type."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:BiomarqueurImmunologique .

promess:ADN a owl:Class ;
    rdfs:label "ADN"@fr ;
    rdfs:comment "DNA derived from blood sample."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Sang .

promess:ARN a owl:Class ;
    rdfs:label "ARN"@fr ;
    rdfs:comment "RNA derived from blood sample."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Sang .

promess:Alexithymie a owl:Class ;
    rdfs:label "Alexithymie"@fr ;
    rdfs:comment "Alexithymia-related psychological factor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurPsychologique .

promess:AntecedentMedical a owl:Class ;
    rdfs:label "AntécédentMédical"@fr ;
    rdfs:comment "Medical history concept kept distinct from comorbidity."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurClinique .

promess:Anxiete a owl:Class ;
    rdfs:label "Anxiété"@fr ;
    rdfs:comment "Anxiety-related psychological factor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurPsychologique .

promess:ArthralgiesCliniquementSuspectes a owl:Class ;
    rdfs:label "ArthralgiesCliniquementSuspectes"@fr ;
    rdfs:comment "Clinically suspect arthralgia."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:ConditionMedicale .

promess:ArthriteClinique a owl:Class ;
    rdfs:label "ArthriteClinique"@fr ;
    rdfs:comment "Clinically manifest arthritis."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:ConditionMedicale .

promess:BiomarqueurMicrobiote a owl:Class ;
    rdfs:label "BiomarqueurMicrobiote"@fr ;
    rdfs:comment "Microbiota-related biomarker type."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Biomarqueur .

promess:CRP a owl:Class ;
    rdfs:label "CRP"@fr ;
    rdfs:comment "C-reactive protein biomarker type."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:BiomarqueurImmunologique .

promess:Cannabis a owl:Class ;
    rdfs:label "Cannabis"@fr ;
    rdfs:comment "Cannabis substance."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:SubstanceTabagique .

promess:Cellule a owl:Class ;
    rdfs:label "Cellule"@fr ;
    rdfs:comment "Cell fraction derived from blood."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Sang .

promess:Comorbidite a owl:Class ;
    rdfs:label "Comorbidité"@fr ;
    rdfs:comment "Coexisting medical condition; kept distinct from medical history."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:ConditionMedicale .

promess:ConfirmationEchographique a owl:Class ;
    rdfs:label "ConfirmationÉchographique"@fr ;
    rdfs:comment "Ultrasound-based confirmation result."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:ResultatDeConfirmation .

promess:Coping a owl:Class ;
    rdfs:label "Coping"@fr ;
    rdfs:comment "Coping style or mechanism."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurPsychologique .

promess:Depression a owl:Class ;
    rdfs:label "Dépression"@fr ;
    rdfs:comment "Depression-related psychological factor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurPsychologique .

promess:Dissociation a owl:Class ;
    rdfs:label "Dissociation"@fr ;
    rdfs:comment "Dissociation-related psychological factor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurPsychologique .

promess:DosagePolluants a owl:Class ;
    rdfs:label "DosagePolluants"@fr ;
    rdfs:comment "Pollutant dosage biomarker/result type."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Biomarqueur .

promess:Echographie a owl:Class ;
    rdfs:label "Échographie"@fr ;
    rdfs:comment "Ultrasound examination."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:ExamenImagerie ;
    owl:disjointWith promess:IRM .

promess:Echographiste a owl:Class ;
    rdfs:label "Échographiste"@fr ;
    rdfs:comment "Ultrasound specialist; modeled as a kind of physician."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Medecin .

promess:ExpositionEau a owl:Class ;
    rdfs:label "ExpositionEau"@fr ;
    rdfs:comment "Exposure through water."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:ExpositionEnvironnementale .

promess:ExpositionHormonale a owl:Class ;
    rdfs:label "ExpositionHormonale"@fr ;
    rdfs:comment "Hormonal exposure."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Exposition .

promess:ExpositionMedicamenteuse a owl:Class ;
    rdfs:label "ExpositionMédicamenteuse"@fr ;
    rdfs:comment "Medication-related exposure."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Exposition .

promess:ExpositionMicrobiote a owl:Class ;
    rdfs:label "ExpositionMicrobiote"@fr ;
    rdfs:comment "Microbiota-related exposure/profile."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Exposition .

promess:ExpositionSol a owl:Class ;
    rdfs:label "ExpositionSol"@fr ;
    rdfs:comment "Exposure through soil."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:ExpositionEnvironnementale .

promess:ExpositionStress a owl:Class ;
    rdfs:label "ExpositionStress"@fr ;
    rdfs:comment "Stress-related exposure."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Exposition .

promess:FacteurComportemental a owl:Class ;
    rdfs:label "FacteurComportemental"@fr ;
    rdfs:comment "Behavior-related risk factor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurDeRisque .

promess:FacteurEnvironnemental a owl:Class ;
    rdfs:label "FacteurEnvironnemental"@fr ;
    rdfs:comment "General environmental risk factor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurDeRisque .

promess:FacteurFamilial a owl:Class ;
    rdfs:label "FacteurFamilial"@fr ;
    rdfs:comment "Family history or familial risk factor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurDeRisque .

promess:FacteurGenetique a owl:Class ;
    rdfs:label "FacteurGénétique"@fr ;
    rdfs:comment "Genetic risk factor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurDeRisque .

promess:FacteurRhumatoide a owl:Class ;
    rdfs:label "FacteurRhumatoïde"@fr ;
    rdfs:comment "Rheumatoid factor biomarker type."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:BiomarqueurImmunologique .

promess:GroupeTresHautRisque a owl:Class ;
    rdfs:label "GroupeTrèsHautRisque"@fr ;
    rdfs:comment "Participant group with very high risk profile."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:GroupeDeParticipants ;
    owl:disjointWith promess:GroupeApparentePremierDegre,
        promess:GroupeHautRisqueSansCSA,
        promess:GroupePRDebutante .

promess:Infirmier a owl:Class ;
    rdfs:label "Infirmier"@fr ;
    rdfs:comment "Nurse involved in study care or follow-up."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Investigateur .

promess:MesureClinique a owl:Class ;
    rdfs:label "MesureClinique"@fr ;
    rdfs:comment "Clinical measurement."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Mesure .

promess:MesureExposomique a owl:Class ;
    rdfs:label "MesureExposomique"@fr ;
    rdfs:comment "Exposomic measurement."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Mesure .

promess:ParticulesFines a owl:Class ;
    rdfs:label "ParticulesFines"@fr ;
    rdfs:comment "Fine-particle exposure agent."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:AgentExposition .

promess:PolyarthriteRhumatoide a owl:Class ;
    rdfs:label "PolyarthriteRhumatoïde"@fr ;
    rdfs:comment "Rheumatoid arthritis."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:ConditionMedicale .

promess:ProgressionVersPR a owl:Class ;
    rdfs:label "ProgressionVersPR"@fr ;
    rdfs:comment "Outcome indicating progression toward rheumatoid arthritis."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:ResultatDEvolution ;
    owl:disjointWith promess:NonProgression,
        promess:ProgressionVersArthrite .

promess:Psychologue a owl:Class ;
    rdfs:label "Psychologue"@fr ;
    rdfs:comment "Psychologist involved in study or assessment."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Investigateur .

promess:QualiteDeVie a owl:Class ;
    rdfs:label "QualitéDeVie"@fr ;
    rdfs:comment "Quality of life factor retained under psychological factors."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurPsychologique .

promess:ScoreClinique a owl:Class ;
    rdfs:label "ScoreClinique"@fr ;
    rdfs:comment "Clinical score or index."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurClinique .

promess:Serum a owl:Class ;
    rdfs:label "Sérum"@fr ;
    rdfs:comment "Serum fraction derived from blood."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Sang .

promess:Silice a owl:Class ;
    rdfs:label "Silice"@fr ;
    rdfs:comment "Silica exposure agent."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:AgentExposition .

promess:SoutienSocial a owl:Class ;
    rdfs:label "SoutienSocial"@fr ;
    rdfs:comment "Social support factor retained under psychological factors."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurPsychologique .

promess:Stress a owl:Class ;
    rdfs:label "Stress"@fr ;
    rdfs:comment "Stress-related psychological factor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurPsychologique .

promess:Tabac a owl:Class ;
    rdfs:label "Tabac"@fr ;
    rdfs:comment "Tobacco substance."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:SubstanceTabagique .

promess:TemporaliteBiologie a owl:Class ;
    rdfs:label "TemporalitéBiologie"@fr ;
    rdfs:comment "Biology temporality structure."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Temporalite .

promess:TemporaliteSymptomes a owl:Class ;
    rdfs:label "TemporalitéSymptômes"@fr ;
    rdfs:comment "Symptom temporality structure."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Temporalite .

promess:Viande a owl:Class ;
    rdfs:label "Viande"@fr ;
    rdfs:comment "Meat."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:TypeAliment ;
    owl:disjointWith promess:Boissons,
        promess:Cereales,
        promess:Fruits,
        promess:Legumes,
        promess:Poisson,
        promess:ProduitsLaitiers,
        promess:Snacks,
        promess:Sucreries .

promess:VisiteInclusion a owl:Class ;
    rdfs:label "VisiteInclusion"@fr ;
    rdfs:comment "Inclusion or baseline visit type."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:TypeDeVisite ;
    owl:disjointWith promess:VisiteAnticipee,
        promess:VisiteJ0,
        promess:VisiteS104,
        promess:VisiteS26,
        promess:VisiteS52 .

promess:FacteurBiologique a owl:Class ;
    rdfs:label "FacteurBiologique"@fr ;
    rdfs:comment "Biological risk factor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurDeRisque .

promess:GroupeHautRisqueSansCSA a owl:Class ;
    rdfs:label "GroupeHautRisqueSansCSA"@fr ;
    rdfs:comment "High-risk participant group without CSA."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:GroupeDeParticipants ;
    owl:disjointWith promess:GroupeApparentePremierDegre,
        promess:GroupePRDebutante .

promess:IRM a owl:Class ;
    rdfs:label "IRM"@fr ;
    rdfs:comment "MRI examination."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:ExamenImagerie .

promess:Medecin a owl:Class ;
    rdfs:label "Médecin"@fr ;
    rdfs:comment "Physician involved in participant care or study tasks."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Investigateur .

promess:Poisson a owl:Class ;
    rdfs:label "Poisson"@fr ;
    rdfs:comment "Fish."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:TypeAliment ;
    owl:disjointWith promess:Boissons,
        promess:Cereales,
        promess:Fruits,
        promess:Legumes,
        promess:ProduitsLaitiers,
        promess:Snacks,
        promess:Sucreries .

promess:ProgressionVersArthrite a owl:Class ;
    rdfs:label "ProgressionVersArthrite"@fr ;
    rdfs:comment "Outcome indicating progression toward clinical arthritis."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:ResultatDEvolution ;
    owl:disjointWith promess:NonProgression .

promess:Selles a owl:Class ;
    rdfs:label "Selles"@fr ;
    rdfs:comment "Stool sample."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:PrelevementBiologique ;
    owl:disjointWith promess:Cheveux,
        promess:Ongles,
        promess:Salive,
        promess:Urines .

promess:VisiteJ0 a owl:Class ;
    rdfs:label "VisiteJ0"@fr ;
    rdfs:comment "Day 0 visit type."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:TypeDeVisite ;
    owl:disjointWith promess:VisiteAnticipee,
        promess:VisiteS104,
        promess:VisiteS26,
        promess:VisiteS52 .

promess:aAgentExpositionAir a owl:ObjectProperty ;
    rdfs:label "aAgentExpositionAir"@fr ;
    rdfs:comment "Exposure agent for air exposure. Suggested cardinality: ExpositionAir -> AgentExposition = 0..*."@en ;
    rdfs:domain promess:ExpositionAir ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range promess:AgentExposition ;
    owl:inverseOf promess:agentAirDe .

promess:aAgentExpositionChimique a owl:ObjectProperty ;
    rdfs:label "aAgentExpositionChimique"@fr ;
    rdfs:comment "Exposure agent for chemical exposure. Suggested cardinality: ExpositionChimique -> AgentExposition = 0..*."@en ;
    rdfs:domain promess:ExpositionChimique ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range promess:AgentExposition ;
    owl:inverseOf promess:agentChimiqueDe .

promess:aAgentExpositionPollution a owl:ObjectProperty ;
    rdfs:label "aAgentExpositionPollution"@fr ;
    rdfs:comment "Exposure agent for pollution exposure. Suggested cardinality: ExpositionPollution -> AgentExposition = 0..*."@en ;
    rdfs:domain promess:ExpositionPollution ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range promess:AgentExposition ;
    owl:inverseOf promess:agentPollutionDe .

promess:aAgentExpositionProfessionnelle a owl:ObjectProperty ;
    rdfs:label "aAgentExpositionProfessionnelle"@fr ;
    rdfs:comment "Exposure agent for occupational exposure. Suggested cardinality: ExpositionProfessionnelle -> AgentExposition = 0..*."@en ;
    rdfs:domain promess:ExpositionProfessionnelle ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range promess:AgentExposition ;
    owl:inverseOf promess:agentProfessionnelDe .

promess:aComplementAlimentaire a owl:ObjectProperty ;
    rdfs:label "aComplementAlimentaire"@fr ;
    rdfs:comment "Dietary supplement descriptor. Suggested cardinality: ExpositionAlimentaire -> ComplementAlimentaire = 0..*."@en ;
    rdfs:domain promess:ExpositionAlimentaire ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range promess:ComplementAlimentaire ;
    owl:inverseOf promess:complementDe .

promess:aCondition a owl:ObjectProperty ;
    rdfs:label "aCondition"@fr ;
    rdfs:comment "Participant condition. Suggested cardinality: Participant -> ConditionMedicale = 0..*."@en ;
    rdfs:domain promess:Participant ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range promess:ConditionMedicale ;
    owl:inverseOf promess:conditionChezParticipant .

promess:aEvenement a owl:ObjectProperty ;
    rdfs:label "aEvenement"@fr ;
    rdfs:comment "Study-relevant event for participant. Suggested cardinality: Participant -> Evenement = 0..*."@en ;
    rdfs:domain promess:Participant ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range promess:Evenement ;
    owl:inverseOf promess:concerneParticipantEvenement .

promess:aExamenImagerie a owl:ObjectProperty ;
    rdfs:label "aExamenImagerie"@fr ;
    rdfs:comment "Participant imaging exam. Suggested cardinality: Participant -> ExamenImagerie = 0..*."@en ;
    rdfs:domain promess:Participant ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range promess:ExamenImagerie ;
    owl:inverseOf promess:concerneParticipantExamen .

promess:aFacteurDeRisque a owl:ObjectProperty ;
    rdfs:label "aFacteurDeRisque"@fr ;
    rdfs:comment "General participant-risk-factor relation. Suggested cardinality: Participant -> FacteurDeRisque = 0..*."@en ;
    rdfs:domain promess:Participant ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range promess:FacteurDeRisque ;
    owl:inverseOf promess:facteurConcerneParticipant .

promess:aFacteurExpositionnel a owl:ObjectProperty ;
    rdfs:label "aFacteurExpositionnel"@fr ;
    rdfs:comment "Inverse exposure-risk relation. Suggested cardinality: ConditionMedicale -> Exposition = 0..*."@en ;
    rdfs:domain promess:ConditionMedicale ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range promess:Exposition ;
    owl:inverseOf promess:estFacteurDeRisqueDe .

promess:aFacteurPsychologique a owl:ObjectProperty ;
    rdfs:label "aFacteurPsychologique"@fr ;
    rdfs:comment "Participant psychological factor. Suggested cardinality: Participant -> FacteurPsychologique = 0..*."@en ;
    rdfs:domain promess:Participant ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range promess:FacteurPsychologique ;
    owl:inverseOf promess:facteurPsychologiqueChezParticipant .

promess:aMesure a owl:ObjectProperty ;
    rdfs:label "aMesure"@fr ;
    rdfs:comment "Participant has measurements. Suggested cardinality: Participant -> Mesure = 0..*."@en ;
    rdfs:domain promess:Participant ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range promess:Mesure ;
    owl:inverseOf promess:concerneParticipantMesure .

promess:aPrelevementBiologique a owl:ObjectProperty ;
    rdfs:label "aPrelevementBiologique"@fr ;
    rdfs:comment "Participant biological sample collection. Suggested cardinality: Participant -> PrelevementBiologique = 0..*."@en ;
    rdfs:domain promess:Participant ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range promess:PrelevementBiologique ;
    owl:inverseOf promess:provientDeParticipant .

promess:aResultatClinique a owl:ObjectProperty ;
    rdfs:label "aResultatClinique"@fr ;
    rdfs:comment "General outcome link. Suggested cardinality: Participant -> ResultatClinique = 0..*."@en ;
    rdfs:domain promess:Participant ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range promess:ResultatClinique ;
    owl:inverseOf promess:concerneParticipantResultat .

promess:aScore a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "aScore"@fr ;
    rdfs:comment "Psychological score value. Suggested cardinality: MesurePsychologique -> xsd:decimal = 0..1."@en ;
    rdfs:domain promess:MesurePsychologique ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range xsd:decimal .

promess:aSigneClinique a owl:ObjectProperty ;
    rdfs:label "aSigneClinique"@fr ;
