promess:FrequenceConsommation a owl:Class ;
    rdfs:label "FréquenceConsommation"@fr ;
    rdfs:comment "Consumption frequency descriptor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> .

promess:GroupePRDebutante a owl:Class ;
    rdfs:label "GroupePRDébutante"@fr ;
    rdfs:comment "Early rheumatoid arthritis participant group."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:GroupeDeParticipants .

promess:HabitudeAlimentaire a owl:Class ;
    rdfs:label "HabitudeAlimentaire"@fr ;
    rdfs:comment "Dietary habit pattern descriptor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> .

promess:Investigateur a owl:Class ;
    rdfs:label "Investigateur"@fr ;
    rdfs:comment "Study investigator involved in PROMESS activities."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Personne .

promess:MesurePsychologique a owl:Class ;
    rdfs:label "MesurePsychologique"@fr ;
    rdfs:comment "Psychological measurement."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:decimal ;
            owl:onProperty promess:aScore ],
        promess:Mesure .

promess:ModeCuisson a owl:Class ;
    rdfs:label "ModeCuisson"@fr ;
    rdfs:comment "Cooking mode descriptor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> .

promess:NiveauTransformation a owl:Class ;
    rdfs:label "NiveauTransformation"@fr ;
    rdfs:comment "Degree of food processing descriptor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> .

promess:OrigineAliments a owl:Class ;
    rdfs:label "OrigineAliments"@fr ;
    rdfs:comment "Origin/source of foods descriptor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> .

promess:ParametreAnthropometrique a owl:Class ;
    rdfs:label "ParamètreAnthropométrique"@fr ;
    rdfs:comment "Anthropometric parameter."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:decimal ;
            owl:onProperty promess:taille ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:decimal ;
            owl:onProperty promess:poids ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:decimal ;
            owl:onProperty promess:bmi ],
        promess:FacteurClinique .

promess:RegimeAlimentaire a owl:Class ;
    rdfs:label "RégimeAlimentaire"@fr ;
    rdfs:comment "Dietary regimen descriptor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> .

promess:Salive a owl:Class ;
    rdfs:label "Salive"@fr ;
    rdfs:comment "Saliva sample."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:PrelevementBiologique ;
    owl:disjointWith promess:Cheveux,
        promess:Ongles .

promess:Temporalite a owl:Class ;
    rdfs:label "Temporalité"@fr ;
    rdfs:comment "Time-related structure for follow-up, symptoms, and biology."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> .

promess:VisiteS52 a owl:Class ;
    rdfs:label "VisiteS52"@fr ;
    rdfs:comment "Week 52 visit type."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:TypeDeVisite ;
    owl:disjointWith promess:VisiteAnticipee,
        promess:VisiteS104 .

promess:Cheveux a owl:Class ;
    rdfs:label "Cheveux"@fr ;
    rdfs:comment "Hair sample."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:PrelevementBiologique ;
    owl:disjointWith promess:Ongles .

promess:Fruits a owl:Class ;
    rdfs:label "Fruits"@fr ;
    rdfs:comment "Fruits."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:TypeAliment ;
    owl:disjointWith promess:Boissons,
        promess:Legumes,
        promess:Snacks,
        promess:Sucreries .

promess:MesureBiologique a owl:Class ;
    rdfs:label "MesureBiologique"@fr ;
    rdfs:comment "Biological measurement."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:string ;
            owl:onProperty promess:aUniteBiomarqueur ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:decimal ;
            owl:onProperty promess:aValeurBiomarqueur ],
        promess:Mesure .

promess:ResultatDeConfirmation a owl:Class ;
    rdfs:label "RésultatDeConfirmation"@fr ;
    rdfs:comment "Confirmation-result branch."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass promess:ConditionMedicale ;
            owl:onProperty promess:confirmeCondition ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        promess:ResultatClinique .

promess:Sang a owl:Class ;
    rdfs:label "Sang"@fr ;
    rdfs:comment "Blood sample."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:PrelevementBiologique ;
    owl:disjointWith promess:Cheveux,
        promess:Ongles,
        promess:Salive,
        promess:Selles,
        promess:Urines .

promess:SubstanceTabagique a owl:Class ;
    rdfs:label "SubstanceTabagique"@fr ;
    rdfs:comment "Controlled family for tobacco-related substances."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> .

promess:Symptome a owl:Class ;
    rdfs:label "Symptôme"@fr ;
    rdfs:comment "Participant-reported or observed symptom."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:decimal ;
            owl:onProperty promess:intensiteSymptome ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty promess:presenceSymptome ],
        promess:FacteurClinique .

promess:TempsSuivi a owl:Class ;
    rdfs:label "TempsSuivi"@fr ;
    rdfs:comment "Follow-up time structure."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:integer ;
            owl:onProperty promess:ordreTempsSuivi ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        promess:Temporalite .

promess:VisiteS104 a owl:Class ;
    rdfs:label "VisiteS104"@fr ;
    rdfs:comment "Week 104 visit type."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:TypeDeVisite ;
    owl:disjointWith promess:VisiteAnticipee .

promess:Evenement a owl:Class ;
    rdfs:label "Événement"@fr ;
    rdfs:comment "Relevant event occurring during study follow-up."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass promess:Visite ;
            owl:onProperty promess:survientLorsDe ],
        [ a owl:Restriction ;
            owl:onClass promess:Participant ;
            owl:onProperty promess:concerneParticipantEvenement ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:date ;
            owl:onProperty promess:dateEvenement ] .

promess:ExpositionEnvironnementale a owl:Class ;
    rdfs:label "ExpositionEnvironnementale"@fr ;
    rdfs:comment "Intermediate environmental exposure class."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:Exposition .

promess:FacteurClinique a owl:Class ;
    rdfs:label "FacteurClinique"@fr ;
    rdfs:comment "Clinical risk factor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurDeRisque .

promess:Legumes a owl:Class ;
    rdfs:label "Légumes"@fr ;
    rdfs:comment "Vegetables."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:TypeAliment ;
    owl:disjointWith promess:Boissons,
        promess:Snacks,
        promess:Sucreries .

promess:Ongles a owl:Class ;
    rdfs:label "Ongles"@fr ;
    rdfs:comment "Nail sample."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:PrelevementBiologique .

promess:ResultatDEvolution a owl:Class ;
    rdfs:label "RésultatDEvolution"@fr ;
    rdfs:comment "Clinical evolution outcome branch."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass promess:ConditionMedicale ;
            owl:onProperty promess:progresseVersCondition ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        promess:ResultatClinique ;
    owl:disjointWith promess:ResultatDeConfirmation .

promess:VisiteAnticipee a owl:Class ;
    rdfs:label "VisiteAnticipée"@fr ;
    rdfs:comment "Unscheduled or early visit type."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:TypeDeVisite .

promess:Boissons a owl:Class ;
    rdfs:label "Boissons"@fr ;
    rdfs:comment "Beverages."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:TypeAliment ;
    owl:disjointWith promess:Snacks,
        promess:Sucreries .

promess:ResultatClinique a owl:Class ;
    rdfs:label "RésultatClinique"@fr ;
    rdfs:comment "Clinical outcome or confirmation result."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:date ;
            owl:onProperty promess:dateResultat ],
        [ a owl:Restriction ;
            owl:onClass promess:Participant ;
            owl:onProperty promess:concerneParticipantResultat ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:string ;
            owl:onProperty promess:commentaireClinique ] .

promess:SigneClinique a owl:Class ;
    rdfs:label "SigneClinique"@fr ;
    rdfs:comment "Clinically observed sign."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurClinique .

promess:Biomarqueur a owl:Class ;
    rdfs:label "Biomarqueur"@fr ;
    rdfs:comment "Biological marker evaluated by measurement or analysis."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurBiologique .

promess:Snacks a owl:Class ;
    rdfs:label "Snacks"@fr ;
    rdfs:comment "Snack foods."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:TypeAliment ;
    owl:disjointWith promess:Sucreries .

promess:ExamenImagerie a owl:Class ;
    rdfs:label "ExamenImagerie"@fr ;
    rdfs:comment "Imaging examination performed during follow-up."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass promess:Visite ;
            owl:onProperty promess:examenRealiseLorsDe ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass promess:Participant ;
            owl:onProperty promess:concerneParticipantExamen ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] .

promess:Sucreries a owl:Class ;
    rdfs:label "Sucreries"@fr ;
    rdfs:comment "Sweets."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:TypeAliment .

promess:GroupeDeParticipants a owl:Class ;
    rdfs:label "GroupeDeParticipants"@fr ;
    rdfs:comment "Cohort subgroup used to organize participants."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> .

promess:Lieu a owl:Class ;
    rdfs:label "Lieu"@fr ;
    rdfs:comment "Site, center, place, or physical location."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:decimal ;
            owl:onProperty promess:longitude ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:decimal ;
            owl:onProperty promess:latitude ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:string ;
            owl:onProperty promess:nomLieu ] .

promess:AgentExposition a owl:Class ;
    rdfs:label "AgentExposition"@fr ;
    rdfs:comment "Controlled family for exposure agents."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> .

promess:TypeDeVisite a owl:Class ;
    rdfs:label "TypeDeVisite"@fr ;
    rdfs:comment "Controlled type used to classify visits such as J0 or S26."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty promess:codeTypeDeVisite ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] .

promess:Etude a owl:Class ;
    rdfs:label "Étude"@fr ;
    rdfs:comment "Research study or protocol in which participants are followed."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty promess:identifiantEtude ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass promess:Lieu ;
            owl:onProperty promess:aSite ] .

promess:FacteurDeRisque a owl:Class ;
    rdfs:label "FacteurDeRisque"@fr ;
    rdfs:comment "Any factor associated with increased disease risk."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> .

promess:TypeAliment a owl:Class ;
    rdfs:label "TypeAliment"@fr ;
    rdfs:comment "Food type descriptor class."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> .

promess:Exposition a owl:Class ;
    rdfs:label "Exposition"@fr ;
    rdfs:comment "Any exposure relevant to the participant or disease process."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass promess:Participant ;
            owl:onProperty promess:concerneParticipantExposition ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] .

promess:FacteurPsychologique a owl:Class ;
    rdfs:label "FacteurPsychologique"@fr ;
    rdfs:comment "Psychological risk factor."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf promess:FacteurDeRisque .

promess:Mesure a owl:Class ;
    rdfs:label "Mesure"@fr ;
    rdfs:comment "Any measurement collected in the study."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:string ;
            owl:onProperty promess:aValeurTexte ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:string ;
            owl:onProperty promess:aUnite ],
        [ a owl:Restriction ;
            owl:onClass promess:Visite ;
            owl:onProperty promess:estRealiseeLorsDe ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass promess:Participant ;
            owl:onProperty promess:concerneParticipantMesure ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:decimal ;
            owl:onProperty promess:aValeurNumerique ] .

promess:PrelevementBiologique a owl:Class ;
    rdfs:label "PrélèvementBiologique"@fr ;
    rdfs:comment "Biological sample collected from a participant."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass promess:Visite ;
            owl:onProperty promess:prelevementRealiseLorsDe ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass promess:Participant ;
            owl:onProperty promess:provientDeParticipant ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] .

promess:ConditionMedicale a owl:Class ;
    rdfs:label "ConditionMédicale"@fr ;
    rdfs:comment "Disease, syndrome, comorbidity, or medically relevant condition."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> .

promess:ExpositionAlimentaire a owl:Class ;
    rdfs:label "ExpositionAlimentaire"@fr ;
    rdfs:comment "Dietary exposure."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass promess:ConsommationEau ;
            owl:onProperty promess:aConsommationEau ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass promess:ModeCuisson ;
            owl:onProperty promess:aModeCuisson ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass promess:RegimeAlimentaire ;
            owl:onProperty promess:aRegimeAlimentaire ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass promess:NiveauTransformation ;
            owl:onProperty promess:aNiveauTransformation ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass promess:OrigineAliments ;
            owl:onProperty promess:aOrigineAliments ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass promess:FrequenceConsommation ;
            owl:onProperty promess:aFrequenceConsommation ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass promess:HabitudeAlimentaire ;
            owl:onProperty promess:aHabitudeAlimentaire ],
        promess:Exposition .

promess:Visite a owl:Class ;
    rdfs:label "Visite"@fr ;
    rdfs:comment "Study encounter or protocol visit."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass promess:TempsSuivi ;
            owl:onProperty promess:aTemporalite ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass promess:TypeDeVisite ;
            owl:onProperty promess:aTypeDeVisite ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass promess:Lieu ;
            owl:onProperty promess:seDerouleDans ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass promess:Participant ;
            owl:onProperty promess:concerneParticipant ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass promess:Etude ;
            owl:onProperty promess:appartientAEtude ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:date ;
            owl:onProperty promess:dateVisite ] .

promess:Participant a owl:Class ;
    rdfs:label "Participant"@fr ;
    rdfs:comment "Person enrolled or followed in the study."@en ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass promess:Etude ;
            owl:onProperty promess:estSuiviDans ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass promess:GroupeDeParticipants ;
            owl:onProperty promess:appartientAuGroupe ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty promess:identifiantParticipant ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        promess:Personne .

<https://w3id.org/promess/ontology> a owl:Ontology ;
    rdfs:label "PROMESS Ontology"@en,
        "Ontologie PROMESS"@fr ;
    dcterms:created "2026-04-06"^^xsd:date ;
    dcterms:creator "Lylia Abrouk",
        "Nushrat Jahan",
        "Sandra Bringay",
        "Zubeyir Salis" ;
    dcterms:description "Draft version of the PROMESS ontology prepared for conceptual modeling, review, documentation, and further refinement."@en,
        "Version préliminaire de l’ontologie PROMESS préparée pour la modélisation conceptuelle, la revue, la documentation et l’affinement ultérieur."@fr ;
    dcterms:language "en",
        "fr" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:modified "2026-04-06"^^xsd:date ;
    dcterms:publisher "Université de Montpellier, LIRMM; INSERM, PhyMedExp"@fr ;
    dcterms:title "PROMESS Ontology"@en,
        "Ontologie PROMESS"@fr ;
    vann:preferredNamespacePrefix "promess" ;
    vann:preferredNamespaceUri "https://w3id.org/promess/ontology#" ;
    owl:versionIRI <https://w3id.org/promess/ontology/0.1-draft> ;
    owl:versionInfo "Draft v0.1"@en .

