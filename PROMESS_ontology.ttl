    rdfs:comment "Inverse processing descriptor relation. Suggested cardinality: NiveauTransformation -> ExpositionAlimentaire = 0..*."@en ;
    rdfs:domain promess:NiveauTransformation ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range promess:ExpositionAlimentaire ;
    owl:inverseOf promess:aNiveauTransformation .

promess:nomLieu a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "nomLieu"@fr ;
    rdfs:comment "Human-readable place or site name. Suggested cardinality: Lieu -> xsd:string = 0..1."@en ;
    rdfs:domain promess:Lieu ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range xsd:string .

promess:ordreTempsSuivi a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "ordreTempsSuivi"@fr ;
    rdfs:comment "Numeric order for longitudinal follow-up. Suggested cardinality: TempsSuivi -> xsd:integer = 1."@en ;
    rdfs:domain promess:TempsSuivi ;
    rdfs:isDefinedBy <https://w3id.org/promess/ontology> ;
    rdfs:range xsd:integer .

promess:origineDe a owl:ObjectProperty ;
    rdfs:label "origineDe"@fr ;
